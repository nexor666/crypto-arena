# === SECRETS & PERSONAL INFO — never commit ===
.env
.env.*
!.env.example          # the only env file allowed (blank template)
*.key
*.pem
*.secret
secrets/
*credentials*
*password*
config.local.*

# === Personal / financial data & the live database ===
/data/                 # root SQLite + raw cache (regenerable, bulky). Anchored to repo
                       # root so it does NOT also ignore backend/data/ (the data-layer code).
*.db
*.sqlite*
*.csv

# === AI coding-tool artifacts (configs/history/state can reference secrets) ===
.claude/               # local Claude Code settings/state (settings.local.json, etc.)
.mcp.json              # MCP server configs — frequently hold inline API keys/tokens
.cursor/
.windsurf/
.codeium/
.continue/
.copilot/
.aider*                # aider chat history + .aider.conf.yml (can contain keys)
.specstory/            # AI chat-history extension
.history/              # VS Code Local History snapshots (may capture secrets)

# === Logs / temp (agents occasionally write secrets here) ===
*.log
tmp/
.cache/

# === Python / OS / editor cruft ===
__pycache__/
*.py[cod]
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
