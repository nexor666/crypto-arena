# === SECRETS & PERSONAL INFO — never commit ===
.env
.env.*
# the only env file allowed (blank template)
!.env.example
*.key
*.pem
*.secret
secrets/
*credentials*
*password*
config.local.*

# === Personal / financial data & the live database ===
# root SQLite + raw cache (regenerable, bulky). Anchored to the repo root with a
# leading slash so it does NOT also ignore backend/data/ (the data-layer CODE).
/data/
*.db
*.sqlite*
*.csv

# === AI coding-tool artifacts (configs/history/state can reference secrets) ===
# local Claude Code settings/state (settings.local.json, etc.)
.claude/
# MCP server configs — frequently hold inline API keys/tokens
.mcp.json
.cursor/
.windsurf/
.codeium/
.continue/
.copilot/
# aider chat history + .aider.conf.yml (can contain keys)
.aider*
# AI chat-history extension
.specstory/
# VS Code Local History snapshots (may capture secrets)
.history/

# === Logs / temp (agents occasionally write secrets here) ===
*.log
tmp/
.cache/

# === Python / OS / editor cruft ===
__pycache__/
*.py[cod]
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
